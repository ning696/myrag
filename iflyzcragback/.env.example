# ==========================================================================
# myrag 后端环境变量模板
# 用法：
#   cp .env.example .env
#   填写下方值后，由 IDE / Spring Boot 加载（IntelliJ EnvFile 插件、
#   VS Code launch.json 或 docker-compose env_file），或导出到当前 shell。
# 注意：.env 已加入 .gitignore，本模板（.env.example）会被提交。
# ==========================================================================

# ------------------ 必需 ------------------

# MySQL（默认 localhost:3306/myrag）
MYSQL_HOST=
MYSQL_PORT=
MYSQL_DB=
MYSQL_USERNAME=root
MYSQL_PASSWORD=

# Milvus（默认 localhost:19530，本地 standalone 通常无需账号密码）
MILVUS_HOST=
MILVUS_PORT=
MILVUS_USERNAME=
MILVUS_PASSWORD=

# LLM Provider —— DeepSeek（OpenAI 兼容）
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-pro
DEEPSEEK_API_KEY=

JINA_API_KEY=
# Embedding Provider —— 阿里云 DashScope（云端向量化，已晋升为必需项）
# 控制台申请：https://bailian.console.aliyun.com
# 可选模型：text-embedding-v1 (1536) / v2 (1536) / v3 (1024)
# 切换模型时记得同步修改 application.yml 中的 milvus.dimension
DASHSCOPE_API_KEY=
EMBEDDING_MODEL=text-embedding-v2

# JWT 签名密钥（至少 256 位随机串）
# 生成命令：openssl rand -base64 64
JWT_SECRET=

# ------------------ 可选 ------------------

# Redis（缓存 / JWT 黑名单 / 登录失败计数）
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# 文件上传目录（默认 ./data/uploads）
FILE_UPLOAD_DIR=./data/uploads

# MinIO 对象存储（minio.enabled=false 时不需要填）
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=

# SMTP 邮件服务（EmailSkill 使用）
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# 网络搜索 API（WebSearchPlugin 使用，默认 Bing）
SEARCH_API_KEY=
SEARCH_ENDPOINT=https://api.tavily.com/search

# 天气 API（WeatherSkill 使用，默认和风天气）
WEATHER_API_KEY=
WEATHER_API_HOST=

TAVILY_API_KEY=